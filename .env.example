NODE_ENV=development
PORT=5000

# Database (Neon PostgreSQL or Local PG)
DATABASE_URL="postgresql://user:password@host:port/dbname?sslmode=require"

# JWT
JWT_SECRET=your_super_secret_jwt_key
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=24h

# Reset Token
RESET_TOKEN_EXPIRES_HOURS=24

# Email (SMTP Configuration)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# Frontend URL (for CORS and redirect links)
FRONTEND_URL=https://hrms-blush-iota.vercel.app

# Default Super Admin (seeder)
ADMIN_EMAIL=admin@hrms.com
ADMIN_PASSWORD=Admin@1234

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
